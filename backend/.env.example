# Server
PORT=3001
NODE_ENV=development

# Database
MONGODB_URI=mongodb://admin:password@localhost:27017/bemft_db?authSource=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=super-secret-key
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=refresh-secret-key
REFRESH_TOKEN_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://api.bemftunesa.org/v1/auth/google/callback
GOOGLE_DRIVE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# Storage (Supabase)
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-key
SUPABASE_BUCKET=bemft-assets

# Notification (WA Bot/Telegram)
WA_BOT_API_KEY=your-wa-key
TELEGRAM_BOT_TOKEN=your-telegram-token

# Rate Limiting
THROTTLER_TTL=60000
THROTTLER_LIMIT=120
