# ===========================================
# BEM FT UNESA - Environment Configuration
# ===========================================

# Application URLs
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
NEXT_PUBLIC_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_IMS_URL=http://localhost:3002

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Initial Admin (KaBEM) â€” email that gets KaBEM role on first login
INITIAL_ADMIN_EMAIL=your-kabem-email@mhs.unesa.ac.id

# API Backend Configuration
PORT=3001
NODE_ENV=development
MONGODB_URI=mongodb://admin:password@localhost:27017/bemft_db?authSource=admin
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=super-secret-key-change-in-production
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=refresh-secret-key-change-in-production
REFRESH_TOKEN_EXPIRES_IN=7d

# Google Services
GOOGLE_DRIVE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# Storage Configuration
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-key
SUPABASE_BUCKET=bemft-assets

# Notification Services
WA_BOT_API_KEY=your-wa-key
TELEGRAM_BOT_TOKEN=your-telegram-token

# CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,https://bemftunesa.org,https://ims.bemftunesa.org

# Monitoring & Logging
LOG_LEVEL=info
SENTRY_DSN=your-sentry-dsn

# Development Only
SKIP_AUTH=false
MOCK_DATA=true

# Rate Limiting
THROTTLER_TTL=60000
THROTTLER_LIMIT=120
